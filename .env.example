# Database (SQLite file, relative to prisma/)
DATABASE_URL="file:./dev.db"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:7600"
AUTH_TRUST_HOST=true

# Optional Google OAuth (login works with credentials only if unset)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional Cloudflare Turnstile on /register (bot defense). Create the widget
# in the CF dashboard; registration works without it (honeypot + rate limit
# + disposable-domain blocklist stay active either way).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Optional Gmail SMTP for Duo Table invite emails (app password, Notifier
# pattern). Without these, invites are in-app only.
SMTP_USER=""
SMTP_PASS=""
