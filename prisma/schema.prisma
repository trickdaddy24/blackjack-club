generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           String    @default("user")
  chips          Int       @default(10000)
  dealerTips     Int       @default(0)
  lastDailyBonus DateTime?
  // Consecutive winning rounds (pushes don't break the run) — settle-time
  // bookkeeping so streak achievements never need to scan history.
  winStreak      Int       @default(0)
  bestWinStreak  Int       @default(0)
  // Consecutive Vegas days with a claimed daily bonus — boosts the bonus.
  loginStreak    Int       @default(0)
  // Last Vegas day a property-pick bonus was claimed — independent of, and
  // stacks alongside, the flat daily bonus above.
  lastPropertyPick DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  rounds       Round[]
  trainerStat  TrainerStat?
  achievements Achievement[]
}

model Round {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String // "insurance" | "player" | "settled"
  bet       Int
  stateJson String
  netResult Int       @default(0)
  // Side-bet net for the round (PP/21+3/Lucky Ladies/bust bet stakes vs
  // payouts, plus any jackpot won) — netResult tracks the main game only.
  sideNet   Int       @default(0)
  // Shared-table round this row records (one row PER PLAYER at settle).
  // Null = solo. Solo shoe carry-over skips table rounds.
  tableId   String?
  createdAt DateTime  @default(now())
  settledAt DateTime?

  @@index([userId, status])
  @@index([settledAt])
}

// A shared 2-player table (game-agnostic social layer — gameType decides the
// engine). Live round state rides in stateJson; per-player Round rows are
// written only at settle.
model Table {
  id            String    @id @default(cuid())
  gameType      String    @default("blackjack")
  status        String    @default("open") // "open" (no guest) | "active" | "ended"
  hostId        String
  guestId       String?
  stateJson     String? // current/last shared RoundState (carries the shoe)
  hostBet       Int       @default(0) // next-round wagers; 0 = not placed yet
  guestBet      Int       @default(0)
  hostSideJson  String? // {pp,tp,ll} for the next round
  guestSideJson String?
  // Player-phase turn clock; expired = the active hand auto-stands (enforced
  // lazily by whichever request arrives next)
  turnDeadline  DateTime?
  endedReason   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([hostId, status])
  @@index([guestId, status])
}

// Table invite: members-only, 5-minute expiry, superseded when the host
// invites someone else. Expiry/supersession are enforced lazily on read.
model Invite {
  id        String   @id @default(cuid())
  tableId   String
  fromId    String
  toId      String
  status    String   @default("pending") // pending|accepted|canceled|expired|superseded
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([toId, status])
  @@index([tableId, status])
}

// Server-side strategy-trainer record: blind decisions graded by the API
// against its own basic-strategy book. Feeds the Strategy Masters board.
model TrainerStat {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  right     Int      @default(0)
  wrong     Int      @default(0)
  streak    Int      @default(0)
  best      Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Site-wide progressive pots (Lucky Ladies). Seeded on first use; every
// Lucky Ladies stake feeds the pot; a hit pays the whole pot and reseeds.
model Jackpot {
  name      String   @id
  amount    Int
  updatedAt DateTime @updatedAt
}

// Random surprise bonus dropped on a currently-active player, Vegas
// "hot seat" style. Single global row (id "global"); nextDropAt is a
// CAS mutex — whichever request's updateMany claims it runs the draw.
// last* fields are the most recent drop, broadcast to every client via
// /api/game/state so winners get a toast and everyone else gets the
// social-proof nudge.
model HotSeatDrop {
  id             String    @id
  nextDropAt     DateTime
  lastWinnerId   String?
  lastWinnerName String?
  lastAmount     Int?
  lastAwardedAt  DateTime?
}

// Audit trail for the pit-boss console — every mutating admin action writes
// a row. detail is JSON ({amount, reason, before, after, ...}).
model AdminAction {
  id        String   @id @default(cuid())
  adminId   String
  action    String // "chips-adjust" | "role-set" | "achievement-grant" | "achievement-revoke" | "purge"
  targetId  String?
  detail    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Counting Gym drill: server-issued card sequence + truth; the row is the
// grade record. cardsJson ships to the client (it must render them) — the
// personal-stats tradeoff is accepted for Phase 1, like the trainer's
// blind attestation.
model GymDrill {
  id        String   @id @default(cuid())
  userId    String
  level     String
  speedMs   Int
  count     Int
  cardsJson String
  answer    Int // true Hi-Lo running count
  submitted Int?
  correct   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Daily-quest progress: one row per player per Vegas day per quest. The
// catalog and rotation live in code (src/lib/quests.ts); rewards are paid
// the moment `done` flips.
model QuestProgress {
  userId   String
  day      String // Vegas date key, "2026-07-16"
  slug     String
  progress Int     @default(0)
  done     Boolean @default(false)

  @@id([userId, day, slug])
  @@index([day])
}

// Board-champion payouts: one row per closed window per board (amount 0 =
// evaluated, nobody qualified). Awarded lazily by whoever views the boards
// first after the window closes.
model BoardAward {
  id          String   @id @default(cuid())
  board       String // "daily" | "weekly"
  windowStart DateTime
  userId      String?
  amount      Int
  createdAt   DateTime @default(now())

  @@unique([board, windowStart])
}

// One row per unlocked achievement. The catalog (names, conditions, art)
// lives in code (src/lib/achievements.ts) — the DB only records the unlock.
model Achievement {
  userId     String
  slug       String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, slug])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
