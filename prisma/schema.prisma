generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           String    @default("user")
  chips          Int       @default(10000)
  dealerTips     Int       @default(0)
  lastDailyBonus DateTime?
  // Consecutive winning rounds (pushes don't break the run) — settle-time
  // bookkeeping so streak achievements never need to scan history.
  winStreak      Int       @default(0)
  bestWinStreak  Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  rounds       Round[]
  trainerStat  TrainerStat?
  achievements Achievement[]
}

model Round {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String // "insurance" | "player" | "settled"
  bet       Int
  stateJson String
  netResult Int       @default(0)
  // Side-bet net for the round (PP/21+3/Lucky Ladies/bust bet stakes vs
  // payouts, plus any jackpot won) — netResult tracks the main game only.
  sideNet   Int       @default(0)
  createdAt DateTime  @default(now())
  settledAt DateTime?

  @@index([userId, status])
  @@index([settledAt])
}

// Server-side strategy-trainer record: blind decisions graded by the API
// against its own basic-strategy book. Feeds the Strategy Masters board.
model TrainerStat {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  right     Int      @default(0)
  wrong     Int      @default(0)
  streak    Int      @default(0)
  best      Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Site-wide progressive pots (Lucky Ladies). Seeded on first use; every
// Lucky Ladies stake feeds the pot; a hit pays the whole pot and reseeds.
model Jackpot {
  name      String   @id
  amount    Int
  updatedAt DateTime @updatedAt
}

// One row per unlocked achievement. The catalog (names, conditions, art)
// lives in code (src/lib/achievements.ts) — the DB only records the unlock.
model Achievement {
  userId     String
  slug       String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, slug])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
